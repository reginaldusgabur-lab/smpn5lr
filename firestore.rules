rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      let userDocExists = exists(/databases/$(database)/documents/users/$(request.auth.uid));
      let userRole = userDocExists ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : '';
      return (isSignedIn() && request.auth.token.email == 'admin@sekolah.sch.id')
             || (userDocExists && userRole == 'admin');
    }
    
    function isHeadmaster() {
        let userDocExists = exists(/databases/$(database)/documents/users/$(request.auth.uid));
        let userRole = userDocExists ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : '';
        return (isSignedIn() && userDocExists && userRole == 'kepala_sekolah');
    }

    function isPrivileged() {
        return isAdmin() || isHeadmaster();
    }
     
    function docExists() {
      return resource != null;
    }
    
    function isOwnerOfExistingDoc(userId) {
      return isOwner(userId) && docExists();
    }
    
    function incomingUserProfileIsValid(userId) {
      return request.resource.data.id == userId;
    }
    
    function userProfileIdIsImmutable() {
      return request.resource.data.id == resource.data.id;
    }
    
    function incomingSubDocIsValid(userId) {
      return request.resource.data.userId == userId;
    }
    
    function subDocOwnerIsImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    function getMonthlyConfig(date) {
      let year = string(date.year());
      let month = date.month() < 10 ? '0' + string(date.month()) : string(date.month());
      let docId = year + '-' + month;
      return get(/databases/$(database)/documents/monthlyConfigs/$(docId)).data;
    }

    function isWithinCheckInTime() {
      let config = getMonthlyConfig(request.time);
      let endTimeParts = config.checkInEndTime.split(':');
      let endHour = int(endTimeParts[0]);
      let endMinute = int(endTimeParts[1]);
      let requestHour = request.time.inZone('Asia/Makassar').hours;
      let requestMinute = request.time.inZone('Asia/Makassar').minutes;
      return requestHour < endHour || (requestHour == endHour && requestMinute < endMinute);
    }

    function hasNoExistingRecordForDate(userId, date) {
      let year = date.year();
      let month = date.month();
      let day = date.day();
      let dayStart = timestamp.date(year, month, day);
      let dayEnd = dayStart.add(duration.time(24, 0, 0, 0));

      let hasExistingLeave = get(/databases/$(database)/documents/users/$(userId)/leaveRequests
                                .where('startDate', '>=', dayStart)
                                .where('startDate', '<', dayEnd)
                             ).size() > 0;

      let hasExistingAttendance = get(/databases/$(database)/documents/users/$(userId)/attendanceRecords
                                    .where('checkInTime', '>=', dayStart)
                                    .where('checkInTime', '<', dayEnd)
                                  ).size() > 0;

      return !hasExistingLeave && !hasExistingAttendance;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isPrivileged();
      allow list: if isPrivileged();
      allow create: if (isOwner(userId) && incomingUserProfileIsValid(userId)) || isAdmin();
      allow update: if (isOwnerOfExistingDoc(userId) && userProfileIdIsImmutable()) || isAdmin();
      allow delete: if isAdmin();

      match /attendanceRecords/{attendanceRecordId} {
        allow get, list: if isOwner(userId) || isPrivileged();
        allow create: if (isOwner(userId) && incomingSubDocIsValid(userId) && hasNoExistingRecordForDate(userId, request.resource.data.checkInTime) && isWithinCheckInTime()) || isAdmin();
        allow update, delete: if isOwner(userId) || isAdmin();
      }

      match /leaveRequests/{leaveRequestId} {
        allow get, list: if isOwner(userId) || isPrivileged();
        allow create: if isOwner(userId) && incomingSubDocIsValid(userId) && hasNoExistingRecordForDate(userId, request.resource.data.startDate);
        allow update: if isHeadmaster() || (isOwner(userId) && subDocOwnerIsImmutable());
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
    
    match /{path=**}/attendanceRecords/{attendanceRecordId} {
      allow get, list: if exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    match /{path=**}/leaveRequests/{leaveRequestId} {
      allow get, list: if exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    match /schoolConfig/{schoolConfigId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /monthlyConfigs/{yearMonth} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}