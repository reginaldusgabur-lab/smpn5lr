rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Safely get the data of the user making the request
    function getRequestingUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Safely get the role of the user making the request
    function getRequestingUserRole() {
      let userData = getRequestingUserData();
      // Check for document and field existence before access
      if (userData != null && 'role' in userData.data) {
        return userData.data.role;
      }
      // Return a default value to prevent rule evaluation errors
      return ''; 
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && getRequestingUserRole() == 'admin';
    }
    
    function isHeadmaster() {
      return isSignedIn() && getRequestingUserRole() == 'kepala_sekolah';
    }

    function isPrivileged() {
      let role = getRequestingUserRole();
      return isSignedIn() && (role == 'admin' || role == 'kepala_sekolah');
    }
     
    function docExists() {
      return resource != null;
    }
    
    function isOwnerOfExistingDoc(userId) {
      return isOwner(userId) && docExists();
    }
    
    function incomingUserProfileIsValid(userId) {
      return request.resource.data.id == userId;
    }
    
    function userProfileIdIsImmutable() {
      return request.resource.data.id == resource.data.id;
    }
    
    function incomingSubDocIsValid(userId) {
      return request.resource.data.userId == userId;
    }
    
    function subDocOwnerIsImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    // Rules for specific collections
    match /users/{userId} {
      allow get: if isOwner(userId) || isPrivileged();
      allow list: if isPrivileged();
      allow create: if (isOwner(userId) && incomingUserProfileIsValid(userId)) || isAdmin();
      allow update: if (isOwnerOfExistingDoc(userId) && userProfileIdIsImmutable()) || isAdmin();
      allow delete: if isAdmin();

      match /attendanceRecords/{attendanceRecordId} {
        allow get, list: if isOwner(userId) || isPrivileged();
        allow create: if (isOwner(userId) && incomingSubDocIsValid(userId)) || isAdmin();
        allow update, delete: if isOwner(userId) || isAdmin();
      }

      match /leaveRequests/{leaveRequestId} {
        allow get, list: if isOwner(userId) || isPrivileged();
        allow create: if isOwner(userId) && incomingSubDocIsValid(userId);
        allow update: if isHeadmaster() || (isOwner(userId) && subDocOwnerIsImmutable());
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
    
    // Rules for collection groups (for cross-user queries)
    match /{path=**}/attendanceRecords/{attendanceRecordId} {
      allow get, list: if isPrivileged();
    }

    match /{path=**}/leaveRequests/{leaveRequestId} {
      allow get, list: if isPrivileged();
    }

    // Rules for global configuration collections
    match /schoolConfig/{schoolConfigId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /monthlyConfigs/{yearMonth} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
