rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Function ---
    // Checks if the requesting user has a specific role.
    function isRole(role) {
      // This get() call is safe because of the explicit read rule for a user's own document below.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    // --- Collection: users ---
    match /users/{userId} {

      // READ:
      // 1. A user can always read their own document. This is CRITICAL for role-based access to work.
      // 2. An admin or a kepala_sekolah can read ANY user document.
      allow read: if request.auth.uid == userId || isRole('admin') || isRole('kepala_sekolah');

      // LIST:
      // An admin or kepala_sekolah can list the users collection (e.g., for reports and user management).
      allow list: if isRole('admin') || isRole('kepala_sekolah');
      
      // CREATE:
      // Only an admin can create new users.
      allow create: if isRole('admin');

      // UPDATE:
      // A user can update their own profile, OR an admin can update any profile.
      allow update: if request.auth.uid == userId || isRole('admin');

      // DELETE:
      // Only an admin can delete users.
      allow delete: if isRole('admin');
    }

    // --- Sub-collections under users (attendance, leave requests) ---
    match /users/{userId}/{subCollection}/{docId} {
      
      // READ/WRITE (OWNER): The user owns their sub-collection documents.
      allow read, write: if request.auth.uid == userId;
      
      // READ (ADMIN/KEPSEK): Admins and Kepsek can also READ these for reports. (This is additive with the rule above)
      allow read: if isRole('admin') || isRole('kepala_sekolah');

      // UPDATE (KEPSEK): A Kepsek can UPDATE these documents (e.g., to approve leave).
      allow update: if isRole('kepala_sekolah');
    }
    
    // --- Global Configuration & Other Collections ---
    match /schoolConfig/{docId} {
      allow read: if isRole('admin') || isRole('kepala_sekolah');
      allow write: if isRole('admin');
    }

    match /monthlyConfigs/{docId} {
      allow read: if isRole('admin') || isRole('kepala_sekolah');
      allow write: if isRole('admin');
    }

    match /quotes/{quoteId} {
      allow read: if request.auth != null; // Any signed-in user
      allow write: if isRole('admin');
    }

    match /activities/{activityId} {
      allow read: if isRole('admin') || isRole('kepala_sekolah');
      allow create: if request.auth != null; // Any signed-in user
    }
  }
}
